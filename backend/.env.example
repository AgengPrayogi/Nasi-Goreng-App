NODE_ENV=development
PORT=5000

# MongoDB — use a replica set URI for transactions (order completion). See docs/API.md.
MONGODB_URI=mongodb://127.0.0.1:27017/nasi_goreng_polonia?replicaSet=rs0&directConnection=true

# HS256 secret for admin JWT (min 32 random bytes recommended for production)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated browser origins allowed to call the API (required in production)
# Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# After the first admin exists, POST /api/auth/register-admin returns 403 unless true (dev/staging only)
ALLOW_ADMIN_REGISTER=false

# Optional shared secret to verify payment gateway webhooks.
# If unset, webhook endpoint accepts requests without secret verification.
PAYMENT_WEBHOOK_SECRET=change-me-to-a-long-secret

# Queue "day" and ETA (optional overrides). See docs/API.md.
ORDER_BUSINESS_TZ=Asia/Jakarta
ETA_BASE_MINUTES=5
ETA_MINUTES_PER_ITEM=3
ETA_MINUTES_PER_ORDER_AHEAD=5

# If true, PATCH /api/orders/:id/complete requires payment marked paid first
REQUIRE_PAID_BEFORE_COMPLETE=false
